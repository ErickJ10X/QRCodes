# ============================================================================
# ENTORNO Y APLICACIÓN
# ============================================================================
NODE_ENV=development
PORT=3000
APP_PORT=3001
APP_NAME=QR Code Generator
APP_VERSION=1.0.0
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:3000

# ============================================================================
# BASE DE DATOS - PostgreSQL
# ============================================================================
POSTGRES_IMAGE=postgres:18-alpine
DB_USER=qrcode
DB_PASSWORD=postgres
DB_PORT=5432
DB_NAME=qrcode
DATABASE_URL=postgresql://qrcode:postgres@localhost:5432/qrcode

# ============================================================================
# DOCKER VOLUMES - Nombres explícitos
# ============================================================================
POSTGRES_VOLUME_NAME=qrcodes_postgres18_data
REDIS_VOLUME_NAME=qrcodes_redis_data
GEOIP_VOLUME_NAME=qrcodes_geoip_data

# ============================================================================
# REDIS - Cache
# ============================================================================
REDIS_IMAGE=redis:8-alpine
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============================================================================
# AUTENTICACIÓN JWT
# ============================================================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug

# ============================================================================
# GEOLOCALIZACIÓN - MaxMind GeoLite2
# ============================================================================
MAXMIND_ACCOUNT_ID=your-account-id
MAXMIND_LICENSE_KEY=your-license-key
GEOIP_DB_PATH=/app/data/geoip/GeoLite2-City.mmdb

# ============================================================================
# DATABASE SEED (desarrollo)
# ============================================================================
SEED_DATABASE=true

SEED_ADMIN_EMAIL=admin@qrcodes.local
SEED_ADMIN_PASSWORD=Admin123!@#
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User

SEED_USER_EMAIL=user@qrcodes.local
SEED_USER_PASSWORD=User123!@#
SEED_USER_FIRST_NAME=Normal
SEED_USER_LAST_NAME=User
