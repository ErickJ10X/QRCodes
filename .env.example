# ============================================================================
# ENTORNO Y APLICACIÓN
# ============================================================================
NODE_ENV=development
PORT=3000
APP_NAME=QR Code Generator
APP_VERSION=1.0.0

# ============================================================================
# BASE DE DATOS - PostgreSQL
# ============================================================================
DB_USER=qrcode
DB_PASSWORD=postgres
DB_PORT=5432
DB_NAME=qrcode
DATABASE_URL=postgresql://qrcode:postgres@localhost:5432/qrcode

# ============================================================================
# REDIS - Cache
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============================================================================
# AUTENTICACIÓN JWT
# ============================================================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
