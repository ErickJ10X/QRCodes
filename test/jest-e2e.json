{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "maxWorkers": 1,
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^jose$": "<rootDir>/mocks/jose.ts",
    "^uuid$": "<rootDir>/mocks/uuid.ts",
    "^@faker-js/faker$": "<rootDir>/mocks/faker.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
